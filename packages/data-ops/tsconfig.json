{
  "extends": "@workspace/typescript-config/vite-react-library.json",
  "compilerOptions": {
    "target": "ESNext",
    "baseUrl": ".",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@repo/data-ops/*": ["./src/*"]
    },
    "types": ["@cloudflare/workers-types", "vitest/globals", "node"],
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "scripts/listUsers.mjs", "config/auth.ts"],
  "exclude": ["node_modules", "dist"]
}
